# Supabase PostgreSQL connection string
# Get from: Supabase Dashboard → Project Settings → Database → Connection string (URI mode)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# JWT secret — generate a strong random string
SECRET_KEY=change-me-with-a-long-random-string

# Gmail App Password (leave blank for dev mode — OTP shown in API response)
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Public base URL used in QR codes and PDF links
BASE_URL=http://localhost:8000

# Allowed frontend origins
FRONTEND_URL=http://localhost:5173
